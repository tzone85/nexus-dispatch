direction: down

title: |md
  # Agent Hierarchy & Complexity Routing
| {near: top-center; style.font-size: 22; style.bold: true}

req: Requirement {
  shape: oval
  style.fill: "#e8f0fe"
}

tl: Tech Lead\n(qwen3-coder:30b) {
  style.fill: "#fef7e0"
  style.stroke-width: 2
  desc: |md
    Decompose
    Score complexity
    Build DAG
  |
}

router: Complexity router {
  shape: diamond
  style.fill: "#f5f5f5"
}

junior: Junior\n(gemma4:e4b) {
  style.fill: "#e6f4ea"
  desc: |md
    Complexity 1-3
    "Trivial tasks"
  |
}

intermediate: Intermediate\n(gemma4:e4b) {
  style.fill: "#e8eaf6"
  desc: |md
    Complexity 4-5
    "Standard features"
  |
}

senior: Senior\n(qwen3-coder:30b) {
  style.fill: "#fef7e0"
  desc: |md
    Complexity 6-8
    + reviews everyone
    Complexity 9-13 →
    decomposes further
  |
}

reviewer: Code Review\n(senior) {
  style.fill: "#fef7e0"
}

qa: QA\n(qwen3-coder:30b) {
  style.fill: "#fce8e6"
  desc: |md
    Lint + build + test
    Failure analysis
  |
}

supervisor: Supervisor\n(gemma4:e4b) {
  style.fill: "#e8f0fe"
  desc: |md
    Periodic drift detection
    Reprioritization
    Escalation handling
  |
}

merge: Merge to base {
  shape: oval
  style.fill: "#e6f4ea"
}

req -> tl
tl -> router: stories with complexity
router -> junior: 1-3
router -> intermediate: 4-5
router -> senior: 6-8
junior -> reviewer
intermediate -> reviewer
senior -> reviewer
reviewer -> qa: approve
qa -> merge: pass
supervisor -> tl: drift alerts {style.stroke-dash: 3; style.stroke: "#f9ab00"}
supervisor -> router: reprioritize {style.stroke-dash: 3; style.stroke: "#f9ab00"}
